{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>RedHatInsights/konflux-pipelines//renovate/foreman_satellite/renovate.json"
  ],
  "ignorePaths": [
    "Pipfile.iqe",
    ".hermetic_builds/**"
  ],
  "constraints": {
    "python": "3.12"
  },
  "tekton": {
    "schedule": [
      "at any time"
    ]
  },
  "pip_requirements": {
    "enabled": false
  },
  "pip-compile": {
    "enabled": false
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)pyproject\\.toml$", "(^|/)iqe-host-inventory-plugin/pyproject\\.toml$"],
      "matchStrings": ["required-version\\s*=\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "astral-sh/uv",
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [
    {
      "matchPackagePatterns": ["^openapi-"],
      "groupName": "openapi"
    },
    {
      "matchPackagePatterns": ["^opentelemetry-"],
      "groupName": "opentelemetry",
      "ignoreUnstable": false
    }
  ]
}
