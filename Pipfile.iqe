iqe-turnpike-plugin = "*"
lxml = "*"
ocdeployer = "*"
psycopg2-binary = "*"
pytest = "*"
pytest-html = "*"
pytest-lazy-fixtures = "*"
requests = "*"
sqlalchemy = "*"

[requires]
python_version = "3.12"
