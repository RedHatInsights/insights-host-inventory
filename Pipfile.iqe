[[source]]
url = "https://nexus.corp.redhat.com/repository/cqt-pypi/simple"
verify_ssl = true
name = "rhnexus"

[dev-packages]
beautifulsoup4 = "*"
click = "*"
crc-bonfire = "*"
faker = "*"
google-api-python-client = "*"
